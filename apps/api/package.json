{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:init": "tsx scripts/init-db.ts",
    "auth:generate": "better-auth generate",
    "auth:migrate": "better-auth migrate",
    "seed": "tsx src/infrastructure/database/seeds/run-seeds.ts",
    "seed:instrument": "tsx src/infrastructure/database/seeds/sample-instrument.seed.ts",
    "seed:cms": "tsx src/infrastructure/database/seeds/sample-cms-content.seed.ts",
    "seed:template": "tsx src/infrastructure/database/seeds/sample-template.seed.ts",
    "seed:users": "tsx src/infrastructure/database/seeds/sample-users.seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:scoring": "vitest run src/domains/scoring/",
    "test:sharing": "vitest run src/domains/sharing/",
    "test:report": "vitest run src/domains/report/",
    "test:instrument": "vitest run src/domains/instrument/",
    "test:billing": "vitest run src/domains/billing/",
    "test:e2e": "vitest run src/test/e2e/"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@dimensional/shared": "workspace:*",
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@hookform/resolvers": "^5.2.2",
    "@types/node": "^20.12.7",
    "@types/uuid": "^11.0.0",
    "better-auth": "1.6.9",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "^6.1.0",
    "form-data": "^4.0.5",
    "handlebars": "^4.7.9",
    "mailgun.js": "^13.0.1",
    "mathjs": "^15.2.0",
    "pg": "^8.20.0",
    "puppeteer": "^24.43.1",
    "react-hook-form": "^7.75.0",
    "sanitize-html": "^2.17.3",
    "stripe": "^22.1.1",
    "typescript": "^5.4.5",
    "uuid": "^14.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "@types/puppeteer": "^7.0.4",
    "@types/sanitize-html": "^2.16.1",
    "@types/stripe": "^8.0.417",
    "@vitest/coverage-v8": "^4.1.6",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "vitest": "^4.1.5"
  }
}
